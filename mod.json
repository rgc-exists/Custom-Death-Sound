{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "rgc_exists.death_sfx_changer",
	"name": "Custom Death Sound",
	"version": "v2.0.0-beta.7",
	"developers": [ "OmgRod", "RGC Exists" ],
	"description": "A mod for changing death sounds with extra randomization features.",
	"tags": [ "offline", "online", "customization", "content", "gameplay" ],
	"resources": {
		"sprites": [
			"res/sprites/*.png"
		],
		"files": [
			"res/json/*.json"
		]
	},
	"links": {
		"source": "https://github.com/rgc-exists/Custom-Death-Sound"
	},
	"settings": {
		"online-library-button": {
			"type": "custom:button",
			"name": "Online Library"
		},
		"death-sound-enabled": {
			"type": "bool",
			"name": "Enable Custom Death Sound(s)",
			"default": true,
			"enable-if": "!mute-death-sound"
		},
		"server-url": {
			"name": "Server URL",
			"type": "string",
			"default": "https://cds.omgrod.me",
			"description": "Server URL for Death SFX index",
			"match": "(http|https):\\/\\/([\\w_-]+(?:(?:\\.[\\w_-]+)+))([\\w.,@?^=%&:\\/~+#-]*[\\w@?^=%&\\/~+#-])",
            "filter": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ:.-_/0123456789"
		},
		"volume": {
			"name": "Volume",
			"type": "float",
			"default": 1,
			"min": 0.0,
			"max": 3.0,
			"control": {
				"slider-step": 0.05,
				"slider": true,
				"input": true
			}
		},
		"clear-on-reset": {
			"type": "bool",
			"name": "Stop Sound On Reset",
			"default": true
		},
		"pitch-randomization-title": {
			"type": "title",
			"name": "Pitch Randomization",
			"description": "Control the minimum and maximum pitch multiplier for the death sound(s). Setting both to the same value will make it constant."
		},
		"pitch-minimum": {
			"name": "Pitch Minimum",
			"type": "float",
			"default": 1,
			"min": 0.25,
			"max": 2.5,
			"control": {
				"slider-step": 0.05,
				"slider": true,
				"input": true
			}
		},
		"pitch-maximum": {
			"name": "Pitch Maximum",
			"type": "float",
			"default": 1,
			"min": 0.25,
			"max": 2.5,
			"control": {
				"slider-step": 0.05,
				"slider": true,
				"input": true
			}
		},
		"level-complete-title": {
			"type": "title",
			"name": "Level Complete",
			"description": "Easily edit the level complete sound effect. Only one sound is allowed at a time unfortunately..."
		},
		"level-complete-path": {
			"type": "file",
			"name": "Level Complete Sound File",
			"default": "{gd_dir}/resources/endStart_02.ogg",
			"control": {
				"filters": [
					{
						"files": [ "*.ogg", "*.wav", "*.mp3", "*.flac" ],
						"description": "Audio files"
					}
				]
			}
		},
		"level-complete-enabled": {
			"type": "bool",
			"name": "Enable Custom Level Complete Sound",
			"default": false,
			"description": "Play a custom sound when completing a level"
		},
		"level-complete-volume": {
			"name": "Level Complete Volume",
			"type": "float",
			"default": 1,
			"min": 0.0,
			"max": 3.0,
			"control": {
				"slider-step": 0.05,
				"slider": true,
				"input": true
			}
		},
		"misc-title": {
			"name": "Miscellaneous Settings",
			"type": "title"
		}
	},
	"dependencies": {
		"geode.node-ids": ">=v1.20.1"
	}
}