{
	"geode": "5.5.3",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "rgc_exists.custom-death-sound-v2",
	"name": "Custom Death Sound Reimagined",
	"version": "v2.0.0",
	"developers": ["OmgRod", "RGC Exists"],
	"description": "A mod for changing the death sound effect, but with extra randomization features.",
	"tags": [ "offline", "online", "customization", "content", "gameplay" ],
	"resources": {
		"sprites": [
			"res/*.png"
		]
	},
	"links": {
		"source": "https://github.com/rgc-exists/Custom-Death-Sound"
	},
	"settings": {
		"online-library-button": {
			"type": "custom:button",
			"name": "Online Library"
		},
		"death-sound-enabled": {
			"type": "bool",
			"name": "Enable Custom Death Sound(s)",
			"default": true,
			"enable-if": "!mute-death-sound"
		},
		"server-url": {
			"name": "Server URL",
			"type": "string",
			"default": "https://cds.omgrod.me",
			"description": "Server URL for Death SFX index",
			"filter": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890:/.-"
		},
		"volume": {
			"name": "Volume",
			"type": "float",
			"default": 1,
			"min": 0.0,
			"max": 3.0,
			"control": {
				"slider-step": 0.05,
				"slider": true,
				"input": true
			}
		},
		"pitch-randomization-title": {
			"type": "title",
			"name": "Pitch Randomization",
			"description": "Control the minimum and maximum pitch multiplier for the death sound(s). Setting both to the same value will make it constant."
		},
		"pitch-minimum": {
			"name": "Pitch Minimum",
			"type": "float",
			"default": 1,
			"min": 0.25,
			"max": 2.5,
			"control": {
				"slider-step": 0.05,
				"slider": true,
				"input": true
			}
		},
		"pitch-maximum": {
			"name": "Pitch Maximum",
			"type": "float",
			"default": 1,
			"min": 0.25,
			"max": 2.5,
			"control": {
				"slider-step": 0.05,
				"slider": true,
				"input": true
			}
		}
	},
	"dependencies": {
		"geode.node-ids": ">=v1.20.1"
	}
}